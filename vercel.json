{
    "version": 2,
    "functions": {
        "api/**/*.js": {
            "maxDuration": 45,
            "memory": 1024
        }
    },
    "headers": [
        {
            "source": "/",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
                { "key": "Pragma", "value": "no-cache" }
            ]
        },
        {
            "source": "/(.*)\\.html",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
                { "key": "Pragma", "value": "no-cache" }
            ]
        }
    ]
}
